{
  "info": {
    "_postman_id": "2c0736f0-9509-48d3-9250-fcc8f513ec4d",
    "name": "Async Payments Service",
    "description": "Collection for testing Async Payments Service endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Payment",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"idempotency_key\", \"idem-\" + Date.now());"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 202\", function () {",
              "  pm.response.to.have.status(202);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.collectionVariables.set(\"payment_id\", data.payment_id);",
              "",
              "pm.test(\"Payment id is returned\", function () {",
              "  pm.expect(data.payment_id).to.be.a(\"string\").and.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-Key",
            "value": "{{api_key}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotency_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": \"100.00\",\n  \"currency\": \"USD\",\n  \"description\": \"Order #123\",\n  \"metadata\": {\"order_id\": \"123\"},\n  \"webhook_url\": \"https://example.com/webhook\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/payments",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "payments"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Payment By ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test(\"Response contains requested payment\", function () {",
              "  pm.expect(data.payment_id).to.eql(pm.collectionVariables.get(\"payment_id\"));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/payments/{{payment_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "payments",
            "{{payment_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Payment (Idempotency Replay)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 202\", function () {",
              "  pm.response.to.have.status(202);",
              "});",
              "",
              "const data = pm.response.json();",
              "pm.test(\"Idempotency returns same payment_id\", function () {",
              "  pm.expect(data.payment_id).to.eql(pm.collectionVariables.get(\"payment_id\"));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-Key",
            "value": "{{api_key}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotency_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": \"100.00\",\n  \"currency\": \"USD\",\n  \"description\": \"Order #123\",\n  \"metadata\": {\"order_id\": \"123\"},\n  \"webhook_url\": \"https://example.com/webhook\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/payments",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "payments"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "api_key",
      "value": "change-me"
    },
    {
      "key": "idempotency_key",
      "value": ""
    },
    {
      "key": "payment_id",
      "value": ""
    }
  ]
}
